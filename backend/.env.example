# Nexus AI Backend — Environment Variables
# Copy this file to .env and fill in your values

# --- App ---
DEBUG=true
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Default LLM (Developer's key for trial chats) ---
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_API_KEY=your-gemini-api-key

# --- Embeddings (Server-side, always Gemini) ---
GEMINI_EMBEDDING_API_KEY=your-gemini-api-key

# --- Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
## This is for developer's API key encryption and then storing to the DB
ENCRYPTION_KEY=your-fernet-key

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
